---
import { LEMONSQUEEZY, PRICING, SITE } from '../config/products';

const freeHref = SITE.liveLaunch ? LEMONSQUEEZY.freeDownload : '/#notify';
const freeLabel = SITE.liveLaunch ? 'Download Free' : 'Notify me at launch';
const goldHref = SITE.liveLaunch ? LEMONSQUEEZY.goldPurchase : '/#notify';
const goldLabel = SITE.liveLaunch
	? `Get Ultiplay Gold — ${PRICING.goldPrice}`
	: "Reserve founder's pricing";

const rows = [
	{ label: 'Simultaneous players', free: 'Up to 3', gold: 'Unlimited' },
	{ label: 'All video & image formats', free: true, gold: true },
	{ label: 'Drag & drop', free: true, gold: true },
	{ label: 'Smart playlists & play-next queue', free: true, gold: true },
	{ label: 'Layout save / load', free: 'Unlimited', gold: 'Unlimited' },
	{ label: 'Classic Mode', free: true, gold: true },
	{ label: 'Grid Mode', free: true, gold: true },
	{ label: 'Screen Maximize Mode (SMM)', free: true, gold: true },
	{ label: 'Mosaic Mode (aspect-aware)', free: true, gold: true },
	{ label: 'URL & stream playback (YouTube, Twitch, RTSP)', free: true, gold: true },
	{ label: 'Webcam feeds', free: true, gold: true },
	{ label: 'Basic fullscreen', free: true, gold: true },
	{ label: 'Screenshot capture', free: true, gold: true },
	{ label: 'DJ Dashboard', free: false, gold: true },
	{ label: 'Mirror & sync', free: false, gold: true },
	{ label: 'Duplicate playlists', free: false, gold: true },
	{ label: 'Screen recording', free: false, gold: true },
	{ label: 'Advanced shortcuts & player swapping', free: false, gold: true },
	{ label: 'Priority support', free: false, gold: true },
];

const Check = `<svg class="mx-auto h-5 w-5 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>`;
const Dash = `<span class="inline-block h-0.5 w-4 rounded bg-slate-600"></span>`;
---

<section id="pricing" class="relative mx-auto max-w-6xl px-6 py-20 md:py-28">
	<div class="mb-14 text-center">
		<p class="text-sm font-semibold uppercase tracking-widest text-fuchsia-300">Pricing</p>
		<h2 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
			Start free. Go Gold when you're ready.
		</h2>
		<p class="mt-4 text-lg text-slate-300">
			Free gets you all four layout modes, streaming, webcams, and unlimited saved layouts. Go Gold
			for unlimited players, the full DJ Dashboard, and the pro toolkit.
		</p>
	</div>

	<div class="mb-14 grid gap-6 lg:grid-cols-3">
		<div class="relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-8 backdrop-blur lg:col-span-1">
			<p class="text-sm font-semibold uppercase tracking-widest text-slate-400">Free</p>
			<div class="mt-3 flex items-baseline gap-2">
				<span class="text-5xl font-bold text-white">$0</span>
				<span class="text-slate-400">forever</span>
			</div>
			<p class="mt-4 text-slate-400">
				Up to 3 players with the full layout toolkit, streaming, webcams, and unlimited saved
				layouts. No time limits. No credit card.
			</p>
			<ul class="mt-6 space-y-2 text-sm text-slate-300">
				<li class="flex items-start gap-2">
					<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
					Up to 3 simultaneous players
				</li>
				<li class="flex items-start gap-2">
					<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
					All modes: Classic, Grid, SMM, Mosaic
				</li>
				<li class="flex items-start gap-2">
					<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
					Streaming, webcams & smart playlists
				</li>
				<li class="flex items-start gap-2">
					<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
					Unlimited saved layouts
				</li>
			</ul>
			<a
				href={freeHref}
				class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-lg border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
			>
				{SITE.liveLaunch ? (
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"/></svg>
				) : (
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2c0 .5-.2 1-.6 1.4L4 17h5m6 0a3 3 0 1 1-6 0"/></svg>
				)}
				{freeLabel}
			</a>
		</div>

		<div class="relative overflow-hidden rounded-2xl border border-fuchsia-400/40 bg-gradient-to-br from-fuchsia-500/10 via-purple-500/5 to-cyan-400/10 shadow-[0_0_60px_-20px_rgba(217,70,239,0.6)] backdrop-blur lg:col-span-2">
			<div class="pointer-events-none absolute -right-10 -top-10 h-48 w-48 rounded-full bg-fuchsia-500/20 blur-3xl"></div>
			<div class="grid items-stretch md:grid-cols-2">
				<div class="relative overflow-hidden md:order-2">
					<img
						src="/ultiplay-gold.jpg"
						alt="Ultiplay Gold — character with golden mirrored sunglasses reflecting a grid of premium video streams"
						class="h-full w-full object-cover"
						width="1024"
						height="768"
						loading="lazy"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-l from-transparent via-transparent to-[#1a0a1f]/60 md:to-[#1a0a1f]"></div>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#1a0a1f]/80 via-transparent to-transparent md:from-transparent"></div>
				</div>

				<div class="relative p-8 md:order-1">
					<div class="flex items-center justify-between gap-3">
						<p class="text-sm font-semibold uppercase tracking-widest text-fuchsia-200">Gold</p>
						<span class="rounded-full border border-amber-300/40 bg-amber-400/15 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-amber-200">
							Founder's pricing
						</span>
					</div>

					<div class="mt-3 flex items-baseline gap-3">
						<span class="text-5xl font-bold text-white">{PRICING.goldPrice}</span>
						<span class="text-lg text-slate-500 line-through">{PRICING.goldOriginalPrice}</span>
					</div>
					<p class="mt-2 text-xs font-medium uppercase tracking-widest text-fuchsia-300">
						Early adopter price
					</p>

					<div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-xs font-medium text-slate-300">
						<span class="inline-flex items-center gap-1.5">
							<svg class="h-3.5 w-3.5 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							One-time purchase
						</span>
						<span class="inline-flex items-center gap-1.5">
							<svg class="h-3.5 w-3.5 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							Lifetime updates
						</span>
						<span class="inline-flex items-center gap-1.5">
							<svg class="h-3.5 w-3.5 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							No subscription
						</span>
					</div>

					<p class="mt-5 text-slate-300">
						Unlimited players, the full DJ Dashboard for total control, mirror & sync, duplicate
						playlists, and built-in screen recording. The complete pro toolkit.
					</p>

					<ul class="mt-6 grid gap-2 text-sm text-slate-200 sm:grid-cols-2">
						<li class="flex items-start gap-2">
							<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							Unlimited players
						</li>
						<li class="flex items-start gap-2">
							<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							DJ Dashboard
						</li>
						<li class="flex items-start gap-2">
							<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							Mirror & sync
						</li>
						<li class="flex items-start gap-2">
							<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							Duplicate playlists
						</li>
						<li class="flex items-start gap-2">
							<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							Screen recording
						</li>
						<li class="flex items-start gap-2">
							<svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
							Priority support
						</li>
					</ul>

					<a
						href={goldHref}
						class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-fuchsia-500 to-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-[0_0_30px_rgba(217,70,239,0.4)] transition hover:shadow-[0_0_40px_rgba(217,70,239,0.6)]"
					>
						{goldLabel}
						<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
					</a>
					<p class="mt-3 text-center text-[11px] text-slate-400">
						{SITE.liveLaunch
							? 'Secure checkout via Lemon Squeezy · 14-day refund policy · Lifetime updates.'
							: "Get notified the moment Ultiplay Gold is live · Lock in founder's pricing."}
					</p>
				</div>
			</div>
		</div>
	</div>

	<div class="overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur">
		<table class="w-full text-left text-sm">
			<thead class="bg-white/5">
				<tr>
					<th class="px-6 py-4 font-semibold text-white">Feature</th>
					<th class="px-6 py-4 text-center font-semibold text-slate-300">Free</th>
					<th class="px-6 py-4 text-center font-semibold text-fuchsia-200">Gold</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-white/5">
				{rows.map((row) => (
					<tr class="transition hover:bg-white/[0.02]">
						<td class="px-6 py-4 text-slate-200">{row.label}</td>
						<td class="px-6 py-4 text-center text-slate-300">
							{typeof row.free === 'boolean'
								? <Fragment set:html={row.free ? Check : Dash} />
								: <span>{row.free}</span>}
						</td>
						<td class="px-6 py-4 text-center text-slate-100">
							{typeof row.gold === 'boolean'
								? <Fragment set:html={row.gold ? Check : Dash} />
								: <span class="font-medium">{row.gold}</span>}
						</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>
</section>
