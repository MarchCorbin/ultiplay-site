---
---

<section id="top" class="relative isolate overflow-hidden">
	<div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-20 md:py-28 lg:grid-cols-2 lg:gap-16">
		<div class="relative z-10">
			<span
				class="mb-6 inline-flex items-center gap-2 rounded-full border border-fuchsia-400/30 bg-fuchsia-500/10 px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-fuchsia-200"
			>
				<span class="h-1.5 w-1.5 rounded-full bg-fuchsia-400 shadow-[0_0_10px_rgba(236,72,153,0.9)]"></span>
				Now in early access
			</span>

			<h1 class="text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl lg:text-7xl">
				<span class="block text-white">Your Play.</span>
				<span class="block bg-gradient-to-r from-fuchsia-400 via-pink-300 to-cyan-300 bg-clip-text text-transparent">
					Your Way.
				</span>
			</h1>

			<p class="mt-5 text-base font-medium uppercase tracking-[0.2em] text-slate-400">
				Watch more · Control everything
			</p>

			<p class="mt-6 max-w-xl text-lg text-slate-300 sm:text-xl">
				Run one perfectly-controlled player or a full multi-screen video wall — Ultiplay scales with
				how you watch. One button snaps every player into a cinematic layout: Classic, Grid, Screen
				Maximize, or the brand-new <span class="font-semibold text-fuchsia-300">Mosaic Mode</span>
				that auto-adapts to each video's aspect ratio.
			</p>

			<div class="mt-10 flex flex-wrap items-center gap-4">
				<a
					href="#pricing"
					class="group relative inline-flex items-center gap-2 overflow-hidden rounded-lg bg-gradient-to-r from-fuchsia-500 to-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-[0_0_30px_rgba(217,70,239,0.4)] transition hover:shadow-[0_0_40px_rgba(217,70,239,0.6)]"
				>
					Download Free
					<svg class="h-4 w-4 transition group-hover:translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 5v14M5 12l7 7 7-7"></path>
					</svg>
				</a>
				<a
					href="#demo"
					class="inline-flex items-center gap-2 rounded-lg border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/10"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
						<path d="M8 5v14l11-7z"></path>
					</svg>
					Watch the demo
				</a>
			</div>

			<dl class="mt-12 grid grid-cols-3 gap-6 border-t border-white/10 pt-8 text-sm">
				<div>
					<dt class="text-slate-400">Simultaneous players</dt>
					<dd class="mt-1 text-2xl font-bold text-white">Unlimited</dd>
				</div>
				<div>
					<dt class="text-slate-400">Early adopter</dt>
					<dd class="mt-1 text-2xl font-bold text-white">$14.99</dd>
				</div>
				<div>
					<dt class="text-slate-400">Platforms</dt>
					<dd class="mt-1 text-2xl font-bold text-white">Windows</dd>
				</div>
			</dl>
		</div>

		<div class="relative">
			<div class="absolute -inset-8 -z-10 rounded-[2rem] bg-gradient-to-br from-fuchsia-500/30 via-purple-500/20 to-cyan-400/20 blur-3xl"></div>
			<div class="relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-2xl shadow-fuchsia-500/10 backdrop-blur">
				<img
					src="/ultiplay-hero.jpg"
					alt="Ultiplay — character wearing sunglasses reflecting a grid of video streams"
					class="h-auto w-full"
					width="1024"
					height="768"
					fetchpriority="high"
				/>
				<div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#070310] via-transparent to-transparent"></div>
			</div>
		</div>
	</div>
</section>
