---
import { LEMONSQUEEZY, SITE } from '../config/products';

const year = new Date().getFullYear();
const supportEmail = 'support@ultiplay.net';
const ctaHref = SITE.liveLaunch ? LEMONSQUEEZY.freeDownload : '/#notify';
const ctaLabel = SITE.liveLaunch ? 'Download Free' : 'Launch waitlist';
---

<footer class="mt-10 border-t border-white/5 py-12">
	<div class="mx-auto max-w-6xl px-6">
		<p class="text-center text-2xl font-bold tracking-tight">
			<span class="text-white">Your Play.</span>
			<span class="bg-gradient-to-r from-fuchsia-400 to-cyan-300 bg-clip-text text-transparent">Your Way.</span>
			<span class="text-slate-500"> — Ultiplay.</span>
		</p>

		<div class="mt-8 grid gap-10 border-t border-white/5 pt-10 text-sm text-slate-400 sm:grid-cols-2 md:grid-cols-4">
			<div>
				<div class="flex items-center gap-2 text-white">
					<span class="relative grid h-6 w-6 grid-cols-3 grid-rows-3 gap-[1.5px] rounded-md border border-white/10 bg-slate-950 p-[2px]" aria-hidden="true">
						<span class="col-span-2 row-span-2 rounded-[2px] bg-gradient-to-br from-fuchsia-500 to-pink-500"></span>
						<span class="col-span-1 row-span-2 rounded-[2px] bg-gradient-to-br from-cyan-400 to-blue-500"></span>
						<span class="col-span-3 row-span-1 rounded-[2px] bg-gradient-to-r from-amber-400 via-fuchsia-500 to-cyan-400"></span>
					</span>
					<span class="font-semibold">Ultiplay</span>
				</div>
				<p class="mt-3 text-slate-500">
					The multi-video player that scales with how you watch.
				</p>
			</div>

			<div>
				<p class="text-xs font-semibold uppercase tracking-widest text-slate-500">Product</p>
				<ul class="mt-3 space-y-2">
					<li><a href="/#modes" class="transition hover:text-white">Layout modes</a></li>
					<li><a href="/#features" class="transition hover:text-white">Features</a></li>
					<li><a href="/#pricing" class="transition hover:text-white">Pricing</a></li>
					<li><a href={ctaHref} class="transition hover:text-white">{ctaLabel}</a></li>
				</ul>
			</div>

			<div>
				<p class="text-xs font-semibold uppercase tracking-widest text-slate-500">Support</p>
				<ul class="mt-3 space-y-2">
					<li><a href="/contact" class="transition hover:text-white">Contact</a></li>
					<li><a href={`mailto:${supportEmail}`} class="transition hover:text-white">{supportEmail}</a></li>
				</ul>
			</div>

			<div>
				<p class="text-xs font-semibold uppercase tracking-widest text-slate-500">Legal</p>
				<ul class="mt-3 space-y-2">
					<li><a href="/privacy" class="transition hover:text-white">Privacy Policy</a></li>
					<li><a href="/terms" class="transition hover:text-white">Terms of Service</a></li>
				</ul>
			</div>
		</div>

		<div class="mt-10 border-t border-white/5 pt-6 text-center text-xs text-slate-500">
			© {year} Ultiplay. All rights reserved.
		</div>
	</div>
</footer>
