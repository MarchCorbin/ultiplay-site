---
const year = new Date().getFullYear();
---

<footer class="mt-10 border-t border-white/5 py-12">
	<div class="mx-auto max-w-6xl px-6">
		<p class="text-center text-2xl font-bold tracking-tight">
			<span class="text-white">Your Play.</span>
			<span class="bg-gradient-to-r from-fuchsia-400 to-cyan-300 bg-clip-text text-transparent">Your Way.</span>
			<span class="text-slate-500"> — Ultiplay.</span>
		</p>

		<div class="mt-8 flex flex-col items-center justify-between gap-4 border-t border-white/5 pt-6 text-sm text-slate-500 md:flex-row">
			<div class="flex items-center gap-2">
				<span class="relative inline-flex h-6 w-6 items-center justify-center rounded-md bg-gradient-to-br from-fuchsia-500 to-cyan-400 text-xs font-black text-slate-950">
					U
				</span>
				<span>© {year} Ultiplay. All rights reserved.</span>
			</div>
			<div class="flex items-center gap-6">
				<a href="#modes" class="transition hover:text-white">Modes</a>
				<a href="#features" class="transition hover:text-white">Features</a>
				<a href="#pricing" class="transition hover:text-white">Pricing</a>
				<a href="https://github.com/MarchCorbin/ultiplay-site" class="transition hover:text-white">GitHub</a>
			</div>
		</div>
	</div>
</footer>
