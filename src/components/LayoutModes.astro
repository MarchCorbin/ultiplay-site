---
type Mode = {
	name: string;
	shortcut: string;
	description: string;
	image: string;
	video?: string;
	imageAlt: string;
};

const modes: Mode[] = [
	{
		name: 'Classic',
		shortcut: 'C',
		description:
			'Single-player focus. Full window, no distractions. Perfect for everyday watching with smart playlists and a play-next queue.',
		image: '/modes/classic.webp',
		video: '/modes/classic.mp4',
		imageAlt: 'Ultiplay in Classic Mode — a single video player filling the window',
	},
	{
		name: 'Grid',
		shortcut: 'G',
		description:
			"Auto-arrange every player into an equal grid. 2×2, 3×3, or whatever fits — instantly, with one keystroke.",
		image: '/modes/grid.webp',
		imageAlt: 'Ultiplay in Grid Mode — multiple video players arranged in an equal grid',
	},
	{
		name: 'Screen Maximize',
		shortcut: 'F',
		description:
			'Spread players across every monitor with smart per-screen optimization. Built for multi-monitor rigs and video walls.',
		image: '/modes/smm.webp',
		video: '/modes/smm.mp4',
		imageAlt: 'Ultiplay in Screen Maximize Mode — players distributed across multiple monitors',
	},
	{
		name: 'Mosaic',
		shortcut: 'M',
		description:
			"Adapts dynamically to each video's aspect ratio for a perfectly cinematic layout. No black bars. No awkward gaps.",
		image: '/modes/mosaic.webp',
		imageAlt: 'Ultiplay in Mosaic Mode — players auto-fitted to varying aspect ratios',
	},
];
---

<section id="modes" class="relative mx-auto max-w-6xl px-6 py-20 md:py-28">
	<div class="mb-16 max-w-3xl">
		<p class="text-sm font-semibold uppercase tracking-widest text-fuchsia-300">Layout modes</p>
		<h2 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
			Cinematic layouts. <span class="bg-gradient-to-r from-fuchsia-400 to-cyan-300 bg-clip-text text-transparent">One button.</span>
		</h2>
		<p class="mt-4 text-lg text-slate-300">
			Whether you're running one player or nine, Ultiplay snaps everything into the perfect arrangement
			instantly — automatically optimized for your videos' aspect ratios and your screens.
		</p>
	</div>

	<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
		{modes.map((mode) => (
			<div class="group relative flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-5 backdrop-blur transition hover:border-fuchsia-400/40 hover:bg-white/[0.06]">
				<div class="relative mb-5 aspect-video overflow-hidden rounded-lg border border-white/10 bg-slate-950">
					{mode.video ? (
						<video
							class="h-full w-full object-cover"
							src={mode.video}
							poster={mode.image}
							autoplay
							muted
							loop
							playsinline
							preload="metadata"
							aria-label={mode.imageAlt}
						></video>
					) : (
						<img
							src={mode.image}
							alt={mode.imageAlt}
							class="h-full w-full object-cover"
							loading="lazy"
							decoding="async"
						/>
					)}
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-slate-950/40 via-transparent to-transparent"></div>
				</div>

				<div class="flex items-center justify-between">
					<h3 class="text-lg font-semibold text-white">{mode.name}</h3>
					<kbd class="rounded border border-white/15 bg-white/5 px-2 py-0.5 font-mono text-xs text-slate-300">
						{mode.shortcut}
					</kbd>
				</div>
				<p class="mt-2 flex-1 text-sm leading-relaxed text-slate-400">{mode.description}</p>
			</div>
		))}
	</div>

	<p class="mt-10 text-center text-sm text-slate-500">
		Press a single key. Watch every player snap into place.
	</p>
</section>
