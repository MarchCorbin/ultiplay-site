---
---

<section id="demo" class="relative mx-auto max-w-5xl px-6 py-20">
	<div class="mb-10 text-center">
		<h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
			See Ultiplay in action
		</h2>
		<p class="mt-3 text-slate-400">
			A quick look at what's possible when every screen is yours to command.
		</p>
	</div>

	<div class="relative">
		<div class="absolute -inset-6 -z-10 rounded-[2rem] bg-gradient-to-r from-fuchsia-500/25 to-cyan-400/25 blur-3xl"></div>
		<div class="relative aspect-video overflow-hidden rounded-2xl border border-white/10 bg-black shadow-2xl shadow-fuchsia-500/10">
			<iframe
				class="h-full w-full"
				src="https://www.youtube.com/embed/mCKQj-VgBi4?rel=0&modestbranding=1"
				title="Ultiplay commercial"
				loading="lazy"
				frameborder="0"
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
				allowfullscreen
			></iframe>
		</div>
	</div>
</section>
