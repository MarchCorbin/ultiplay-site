---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import {
	LEGAL_EFFECTIVE_DATE,
	LEGAL_ROUTES,
	PUBLISHER,
	mailtoHref,
	EMAILS,
} from '../config/legal';
---

<Layout
	title="Trademark Notice — Ultiplay"
	description="The Ultiplay name, logo, and slogan are unregistered common-law trademarks of Ultiplay LLC. Here's how you may and may not use them."
>
	<Nav />

	<main class="mx-auto max-w-3xl px-6 py-20 md:py-28">
		<header>
			<p class="text-sm font-semibold uppercase tracking-widest text-fuchsia-300">Legal</p>
			<h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">Trademark Notice</h1>
			<p class="mt-3 text-sm text-slate-500">
				Effective: {LEGAL_EFFECTIVE_DATE} &nbsp;·&nbsp;
				<a href={LEGAL_ROUTES.index} class="underline hover:text-slate-300">Back to legal index</a>
			</p>
		</header>

		<div class="mt-12 space-y-10 text-slate-300">
			<section>
				<p>
					"<strong class="text-white">Ultiplay</strong>™," the Ultiplay logo, and the slogan
					<strong class="text-white"> "Watch More. Control Everything."™</strong> are unregistered
					common-law trademarks of <strong class="text-white">{PUBLISHER.legalName}</strong>. All
					other trademarks, service marks, and logos referenced on the Services are the property of
					their respective owners (see the
					<a href={LEGAL_ROUTES.licenses + '#third-party-trademarks'} class="text-fuchsia-300 underline hover:text-fuchsia-200">third-party trademark notice</a>
					on the open-source licenses page).
				</p>
				<p class="mt-4">
					You may refer to Ultiplay by its trademark name in a factual, non-misleading way (e.g.,
					reviews, news articles, compatibility statements) without prior permission. You may
					<strong class="text-white"> not</strong> use the Ultiplay name or marks in a manner that
					suggests endorsement, sponsorship, or affiliation without our prior written consent, and
					you may not use confusingly similar marks for competing products.
				</p>
				<p class="mt-4">
					For trademark permission requests, contact
					<a href={mailtoHref('legal')} class="text-fuchsia-300 underline hover:text-fuchsia-200">{EMAILS.legal}</a>.
					Press inquiries should go to
					<a href={mailtoHref('press')} class="text-fuchsia-300 underline hover:text-fuchsia-200">{EMAILS.press}</a>.
				</p>
			</section>
		</div>
	</main>

	<Footer />
</Layout>
