---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { DOWNLOAD } from '../config/products';

// The S3 object behind `installerLatest` responds with
// `Content-Disposition: attachment`, so pointing the browser at it triggers a
// file download instead of a navigation — the user stays on this page while
// the installer saves to their Downloads folder.
const installerUrl = DOWNLOAD.installerLatest;
const installerVersion = DOWNLOAD.currentVersion;
---

<Layout
	title="Downloading Ultiplay — your installer is on its way"
	description="Your Ultiplay installer is downloading now. If it doesn't start automatically, use the manual download link."
>
	<Nav />

	<main class="relative mx-auto max-w-3xl px-6 py-24 md:py-32">
		<div
			class="absolute inset-x-0 top-1/3 -z-10 h-96 -translate-y-1/2 bg-[radial-gradient(ellipse_at_center,_rgba(217,70,239,0.18),_transparent_70%)]"
		>
		</div>

		<div
			class="relative overflow-hidden rounded-3xl border border-fuchsia-400/30 bg-gradient-to-br from-fuchsia-500/10 via-purple-500/5 to-cyan-400/10 p-10 text-center backdrop-blur md:p-16"
		>
			<div class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-fuchsia-500/20 blur-3xl"></div>
			<div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-cyan-400/15 blur-3xl"></div>

			<div class="relative">
				<div
					class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-fuchsia-500 to-cyan-400 shadow-[0_0_40px_rgba(217,70,239,0.5)]"
				>
					<svg
						class="h-8 w-8 animate-bounce text-slate-950"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.75"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"></path>
					</svg>
				</div>

				<p class="mt-8 text-sm font-semibold uppercase tracking-widest text-fuchsia-300">
					Your download is starting
				</p>
				<h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
					<span class="block">Ultiplay is on its</span>
					<span
						class="block bg-gradient-to-r from-fuchsia-400 via-pink-300 to-cyan-300 bg-clip-text text-transparent"
					>
						way to your PC.
					</span>
				</h1>

				<p class="mx-auto mt-6 max-w-xl text-lg text-slate-300">
					Check your browser's download bar — <span class="font-semibold text-white">Ultiplay_Setup.exe</span>
					{installerVersion && (
						<>
							<span class="text-slate-500"> (v{installerVersion})</span>
						</>
					)} should be saving now. When it finishes, double-click it to install.
				</p>

				<p class="mx-auto mt-3 max-w-xl text-sm text-slate-400">
					Didn't start, or want to grab it again?
				</p>

				<div class="mt-8 flex flex-wrap items-center justify-center gap-4">
					<a
						id="manual-download"
						href={installerUrl}
						class="group relative inline-flex items-center gap-2 overflow-hidden rounded-lg bg-gradient-to-r from-fuchsia-500 to-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-[0_0_30px_rgba(217,70,239,0.4)] transition hover:shadow-[0_0_40px_rgba(217,70,239,0.6)]"
					>
						<svg
							class="h-4 w-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"></path>
						</svg>
						Restart download
					</a>
					<a
						href="/"
						class="inline-flex items-center gap-2 rounded-lg border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/10"
					>
						<svg
							class="h-4 w-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M19 12H5M12 19l-7-7 7-7"></path>
						</svg>
						Back to home
					</a>
				</div>

				<p class="mt-6 text-xs font-medium uppercase tracking-widest text-slate-500">
					Free · Windows 10 / 11 · 64-bit · No credit card
				</p>
			</div>
		</div>

		<section class="mt-12 grid gap-4 sm:grid-cols-3">
			<div
				class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur"
			>
				<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Step 1</p>
				<p class="mt-3 text-base font-semibold text-white">Run the installer</p>
				<p class="mt-1 text-sm text-slate-400">
					Open <span class="font-mono text-slate-300">Ultiplay_Setup.exe</span> from your Downloads folder.
					Windows SmartScreen may ask you to confirm — click <span class="font-semibold text-white">More info → Run anyway</span>.
				</p>
			</div>

			<div
				class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur"
			>
				<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Step 2</p>
				<p class="mt-3 text-base font-semibold text-white">Launch Ultiplay</p>
				<p class="mt-1 text-sm text-slate-400">
					Drop in a few videos, hit a layout button, and you're in. Classic, Grid, Screen Maximize,
					and Mosaic Mode are all one button away.
				</p>
			</div>

			<a
				href="/#demo"
				class="group rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur transition hover:border-fuchsia-400/30 hover:bg-white/[0.05]"
			>
				<div class="flex items-center justify-between">
					<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">While you wait</p>
					<svg
						class="h-4 w-4 text-slate-500 transition group-hover:translate-x-0.5 group-hover:text-fuchsia-300"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M5 12h14M13 5l7 7-7 7"></path>
					</svg>
				</div>
				<p class="mt-3 text-base font-semibold text-white">Watch the 60-second demo</p>
				<p class="mt-1 text-sm text-slate-400">See exactly what one button can do across four layout modes.</p>
			</a>
		</section>

		<p class="mt-10 text-center text-xs text-slate-500">
			Need help? Email
			<a href="mailto:support@ultiplay.net" class="text-fuchsia-300 underline hover:text-fuchsia-200">
				support@ultiplay.net
			</a>
			— we read every message.
		</p>
	</main>

	<Footer />
</Layout>

<script is:inline define:vars={{ installerUrl }}>
	// Kick off the actual download as soon as the page loads. The S3 object
	// sends `Content-Disposition: attachment`, so the browser triggers a file
	// save dialog instead of navigating away — the branded UI above stays
	// visible the whole time.
	(function startDownload() {
		try {
			var alreadyTriggered = window.sessionStorage.getItem('ultiplay:download-started');
			// Only auto-trigger once per tab session so a manual refresh doesn't
			// spam the user with repeat download prompts.
			if (alreadyTriggered === '1') return;
			window.sessionStorage.setItem('ultiplay:download-started', '1');
		} catch (_) {
			// sessionStorage can throw in private modes — fine, just proceed.
		}
		// Small delay so the page paints first; download still feels instant.
		window.setTimeout(function () {
			window.location.href = installerUrl;
		}, 150);
	})();
</script>
