---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { mailtoHref, EMAILS } from '../config/legal';

const supportEmail = EMAILS.support;

// Topic -> email-key mapping. Used to route a contact-form submission to the
// right specialized address. The mailtoHref() helper currently aliases every
// specialized address back to support@ until the per-address mailboxes are
// live; flip ALIAS_ALL_TO_SUPPORT in src/config/legal.ts to disable the alias.
const topics = [
	{ label: 'General question', emailKey: 'support' as const },
	{ label: 'Support / bug report', emailKey: 'support' as const },
	{ label: 'License or refund', emailKey: 'support' as const },
	{ label: 'Privacy / data-rights request', emailKey: 'privacy' as const },
	{ label: 'Abuse / AUP violation', emailKey: 'abuse' as const },
	{ label: 'Copyright (DMCA)', emailKey: 'dmca' as const },
	{ label: 'Press / partnership', emailKey: 'press' as const },
];

const topicMap = JSON.stringify(
	topics.reduce<Record<string, string>>((acc, t) => {
		const href = mailtoHref(t.emailKey, `[Ultiplay] ${t.label}`);
		acc[t.label] = href.replace(/^mailto:/, '').split('?')[0];
		return acc;
	}, {}),
);
---

<Layout title="Contact — Ultiplay" description="Get in touch with the Ultiplay team for support, partnerships, press, or privacy and copyright inquiries.">
	<Nav />

	<main class="mx-auto max-w-3xl px-6 py-20 md:py-28">
		<header class="text-center">
			<p class="text-sm font-semibold uppercase tracking-widest text-fuchsia-300">Contact</p>
			<h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
				Get in touch.
			</h1>
			<p class="mt-4 text-lg text-slate-300">
				Questions, bug reports, partnership ideas, press, or privacy requests? We read every message.
			</p>
		</header>

		<div class="mt-14 grid gap-8 md:grid-cols-3">
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
				<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Support</p>
				<h2 class="mt-2 text-lg font-bold text-white">App help &amp; licensing</h2>
				<p class="mt-2 text-sm text-slate-400">Best for installer issues, license keys, and refund requests.</p>
				<a href={mailtoHref('support')} class="mt-4 inline-block text-sm font-medium text-fuchsia-300 underline hover:text-fuchsia-200">
					{supportEmail}
				</a>
			</div>
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
				<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Press</p>
				<h2 class="mt-2 text-lg font-bold text-white">Reviews &amp; coverage</h2>
				<p class="mt-2 text-sm text-slate-400">Looking for screenshots, the commercial, or a press kit? Drop a line.</p>
				<a href={mailtoHref('press')} class="mt-4 inline-block text-sm font-medium text-fuchsia-300 underline hover:text-fuchsia-200">
					{EMAILS.press}
				</a>
			</div>
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
				<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Specialized</p>
				<h2 class="mt-2 text-lg font-bold text-white">Privacy, abuse &amp; DMCA</h2>
				<p class="mt-2 text-sm text-slate-400">
					Privacy: <a href={mailtoHref('privacy')} class="text-fuchsia-300 underline hover:text-fuchsia-200">{EMAILS.privacy}</a><br />
					Abuse: <a href={mailtoHref('abuse')} class="text-fuchsia-300 underline hover:text-fuchsia-200">{EMAILS.abuse}</a><br />
					DMCA: <a href={mailtoHref('dmca')} class="text-fuchsia-300 underline hover:text-fuchsia-200">{EMAILS.dmca}</a>
				</p>
			</div>
		</div>

		<section class="mt-16">
			<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-10 backdrop-blur md:p-14">
				<div class="flex items-start justify-between gap-6">
					<div>
						<h2 class="text-2xl font-bold text-white">Compose a message</h2>
						<p class="mt-2 text-sm text-slate-400">
							Fill in the fields and hit send — your email app will open with your message
							pre-addressed to the right inbox based on the topic you pick.
						</p>
					</div>
				</div>

				<form
					id="contact-form"
					data-support-email={supportEmail}
					data-topic-map={topicMap}
					class="mt-8 grid gap-5"
				>
					<div class="grid gap-5 sm:grid-cols-2">
						<div>
							<label for="name" class="block text-xs font-semibold uppercase tracking-widest text-slate-400">Name</label>
							<input
								id="name"
								name="name"
								type="text"
								required
								autocomplete="name"
								class="mt-2 w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-sm text-white placeholder:text-slate-500 outline-none transition focus:border-fuchsia-400/60 focus:ring-2 focus:ring-fuchsia-400/30"
							/>
						</div>
						<div>
							<label for="contact-email" class="block text-xs font-semibold uppercase tracking-widest text-slate-400">Your email</label>
							<input
								id="contact-email"
								name="email"
								type="email"
								required
								autocomplete="email"
								class="mt-2 w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-sm text-white placeholder:text-slate-500 outline-none transition focus:border-fuchsia-400/60 focus:ring-2 focus:ring-fuchsia-400/30"
							/>
						</div>
					</div>
					<div>
						<label for="topic" class="block text-xs font-semibold uppercase tracking-widest text-slate-400">Topic</label>
						<select
							id="topic"
							name="topic"
							class="mt-2 w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-sm text-white outline-none transition focus:border-fuchsia-400/60 focus:ring-2 focus:ring-fuchsia-400/30"
						>
							{topics.map((t) => (
								<option value={t.label}>{t.label}</option>
							))}
						</select>
					</div>
					<div>
						<label for="message" class="block text-xs font-semibold uppercase tracking-widest text-slate-400">Message</label>
						<textarea
							id="message"
							name="message"
							rows="6"
							required
							class="mt-2 w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-sm text-white placeholder:text-slate-500 outline-none transition focus:border-fuchsia-400/60 focus:ring-2 focus:ring-fuchsia-400/30"
						></textarea>
					</div>

					<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
						<p class="text-xs text-slate-500">
							We'll only use your info to respond. See our
							<a href="/privacy" class="underline hover:text-slate-300">privacy policy</a>.
						</p>
						<button
							type="submit"
							class="inline-flex items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-fuchsia-500 to-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-[0_0_30px_rgba(217,70,239,0.4)] transition hover:shadow-[0_0_40px_rgba(217,70,239,0.6)]"
						>
							Open in email app
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
						</button>
					</div>

					<p
						data-form-fallback
						class="hidden rounded-lg border border-amber-300/30 bg-amber-300/5 p-4 text-sm text-amber-200"
						role="alert"
					>
						Your browser didn't open an email app. You can copy your message and send it directly to
						<a href={mailtoHref('support')} class="font-semibold underline hover:text-amber-100">{supportEmail}</a>.
					</p>
				</form>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	if (form) {
		const supportEmail = form.dataset.supportEmail ?? '';
		const topicMap: Record<string, string> = (() => {
			try {
				return JSON.parse(form.dataset.topicMap ?? '{}');
			} catch {
				return {};
			}
		})();
		const fallback = form.querySelector<HTMLElement>('[data-form-fallback]');

		form.addEventListener('submit', (event) => {
			event.preventDefault();
			if (!form.reportValidity()) return;

			const data = new FormData(form);
			const name = String(data.get('name') ?? '').trim();
			const email = String(data.get('email') ?? '').trim();
			const topic = String(data.get('topic') ?? 'General question').trim();
			const message = String(data.get('message') ?? '').trim();

			const targetEmail = topicMap[topic] ?? supportEmail;
			const subject = `[Ultiplay] ${topic} — ${name}`;
			const body = [
				`From: ${name} <${email}>`,
				`Topic: ${topic}`,
				'',
				message,
				'',
				'---',
				'Sent from the contact form on ultiplay.net',
			].join('\n');

			const mailtoURL = `mailto:${targetEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

			fallback?.classList.add('hidden');

			window.location.href = mailtoURL;

			window.setTimeout(() => {
				if (document.visibilityState === 'visible') {
					fallback?.classList.remove('hidden');
				}
			}, 1200);
		});
	}
</script>
