---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// SETUP: replace with your real Formspree endpoint when ready.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/REPLACE_ME';
const supportEmail = 'support@ultiplay.app';
---

<Layout title="Contact — Ultiplay" description="Get in touch with the Ultiplay team for support, partnerships, or press inquiries.">
	<Nav />

	<main class="mx-auto max-w-3xl px-6 py-20 md:py-28">
		<header class="text-center">
			<p class="text-sm font-semibold uppercase tracking-widest text-fuchsia-300">Contact</p>
			<h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
				Get in touch.
			</h1>
			<p class="mt-4 text-lg text-slate-300">
				Questions, bug reports, partnership ideas, or press? We read every message.
			</p>
		</header>

		<div class="mt-14 grid gap-8 md:grid-cols-3">
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
				<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Support</p>
				<h2 class="mt-2 text-lg font-bold text-white">App help & licensing</h2>
				<p class="mt-2 text-sm text-slate-400">Best for installer issues, license keys, and refund requests.</p>
				<a href={`mailto:${supportEmail}`} class="mt-4 inline-block text-sm font-medium text-fuchsia-300 underline hover:text-fuchsia-200">
					{supportEmail}
				</a>
			</div>
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
				<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Press</p>
				<h2 class="mt-2 text-lg font-bold text-white">Reviews & coverage</h2>
				<p class="mt-2 text-sm text-slate-400">Looking for screenshots, the commercial, or a press kit? Drop a line.</p>
				<a href={`mailto:${supportEmail}?subject=Press%20inquiry`} class="mt-4 inline-block text-sm font-medium text-fuchsia-300 underline hover:text-fuchsia-200">
					Email us
				</a>
			</div>
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
				<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Response time</p>
				<h2 class="mt-2 text-lg font-bold text-white">Within 2 business days</h2>
				<p class="mt-2 text-sm text-slate-400">We're a small team — thanks for your patience.</p>
			</div>
		</div>

		<section class="mt-16">
			<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-10 backdrop-blur md:p-14">
				<h2 class="text-2xl font-bold text-white">Send a message</h2>
				<p class="mt-2 text-sm text-slate-400">
					Or use the form below. It goes straight to our support inbox.
				</p>

				<form
					action={FORMSPREE_ENDPOINT}
					method="POST"
					class="mt-8 grid gap-5"
				>
					<div class="grid gap-5 sm:grid-cols-2">
						<div>
							<label for="name" class="block text-xs font-semibold uppercase tracking-widest text-slate-400">Name</label>
							<input
								id="name"
								name="name"
								type="text"
								required
								autocomplete="name"
								class="mt-2 w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-sm text-white placeholder:text-slate-500 outline-none transition focus:border-fuchsia-400/60 focus:ring-2 focus:ring-fuchsia-400/30"
							/>
						</div>
						<div>
							<label for="contact-email" class="block text-xs font-semibold uppercase tracking-widest text-slate-400">Email</label>
							<input
								id="contact-email"
								name="email"
								type="email"
								required
								autocomplete="email"
								class="mt-2 w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-sm text-white placeholder:text-slate-500 outline-none transition focus:border-fuchsia-400/60 focus:ring-2 focus:ring-fuchsia-400/30"
							/>
						</div>
					</div>
					<div>
						<label for="topic" class="block text-xs font-semibold uppercase tracking-widest text-slate-400">Topic</label>
						<select
							id="topic"
							name="topic"
							class="mt-2 w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-sm text-white outline-none transition focus:border-fuchsia-400/60 focus:ring-2 focus:ring-fuchsia-400/30"
						>
							<option value="general">General question</option>
							<option value="support">Support / bug report</option>
							<option value="licensing">License or refund</option>
							<option value="press">Press / partnership</option>
						</select>
					</div>
					<div>
						<label for="message" class="block text-xs font-semibold uppercase tracking-widest text-slate-400">Message</label>
						<textarea
							id="message"
							name="message"
							rows="6"
							required
							class="mt-2 w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-sm text-white placeholder:text-slate-500 outline-none transition focus:border-fuchsia-400/60 focus:ring-2 focus:ring-fuchsia-400/30"
						></textarea>
					</div>
					<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

					<div class="flex items-center justify-between gap-4">
						<p class="text-xs text-slate-500">
							We'll only use your info to respond. See our
							<a href="/privacy" class="underline hover:text-slate-300">privacy policy</a>.
						</p>
						<button
							type="submit"
							class="inline-flex items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-fuchsia-500 to-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-[0_0_30px_rgba(217,70,239,0.4)] transition hover:shadow-[0_0_40px_rgba(217,70,239,0.6)]"
						>
							Send message
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
						</button>
					</div>
				</form>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
