---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// SETUP: in your Formspree dashboard, set the form's "Thank You / Redirect"
// to https://YOUR-DOMAIN/thanks so signups land here after submitting.

// Replace the YouTube URL when ready (or remove the share section entirely).
const commercialUrl = 'https://www.youtube.com/watch?v=mCKQj-VgBi4';
const shareText = encodeURIComponent('Just signed up for early access to Ultiplay — a multi-video player that snaps every player into a cinematic layout with one button. Watch the commercial:');
const twitterShare = `https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(commercialUrl)}`;
---

<Layout
	title="You're on the list — Ultiplay"
	description="Thanks for joining the Ultiplay launch waitlist. We'll email you the moment Gold is purchasable at founder's pricing."
>
	<Nav />

	<main class="relative mx-auto max-w-3xl px-6 py-24 md:py-32">
		<div class="absolute inset-x-0 top-1/3 -z-10 h-96 -translate-y-1/2 bg-[radial-gradient(ellipse_at_center,_rgba(217,70,239,0.18),_transparent_70%)]"></div>

		<div class="relative overflow-hidden rounded-3xl border border-fuchsia-400/30 bg-gradient-to-br from-fuchsia-500/10 via-purple-500/5 to-cyan-400/10 p-10 text-center backdrop-blur md:p-16">
			<div class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-fuchsia-500/20 blur-3xl"></div>
			<div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-cyan-400/15 blur-3xl"></div>

			<div class="relative">
				<div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-br from-fuchsia-500 to-cyan-400 shadow-[0_0_40px_rgba(217,70,239,0.5)]">
					<svg class="h-8 w-8 text-slate-950" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
						<path d="M5 13l4 4L19 7" />
					</svg>
				</div>

				<p class="mt-8 text-sm font-semibold uppercase tracking-widest text-fuchsia-300">You're on the list</p>
				<h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
					<span class="block">Welcome to the</span>
					<span class="block bg-gradient-to-r from-fuchsia-400 via-pink-300 to-cyan-300 bg-clip-text text-transparent">
						Ultiplay launch crew.
					</span>
				</h1>

				<p class="mx-auto mt-6 max-w-xl text-lg text-slate-300">
					We'll email you the moment Ultiplay is purchasable — and you'll get
					<span class="font-semibold text-white">first access to founder's pricing</span>
					before it ratchets up.
				</p>

				<p class="mx-auto mt-4 max-w-xl text-sm text-slate-400">
					Add <a href="mailto:support@ultiplay.net" class="text-fuchsia-300 underline hover:text-fuchsia-200">support@ultiplay.net</a> to your contacts so the launch email lands in your inbox, not your spam folder.
				</p>
			</div>
		</div>

		<section class="mt-12 grid gap-4 sm:grid-cols-3">
			<a
				href="/#modes"
				class="group rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur transition hover:border-fuchsia-400/30 hover:bg-white/[0.05]"
			>
				<div class="flex items-center justify-between">
					<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Explore</p>
					<svg class="h-4 w-4 text-slate-500 transition group-hover:translate-x-0.5 group-hover:text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
				</div>
				<p class="mt-3 text-base font-semibold text-white">See the four layout modes</p>
				<p class="mt-1 text-sm text-slate-400">Classic, Grid, SMM, and Mosaic — every layout one button away.</p>
			</a>

			<a
				href={commercialUrl}
				target="_blank"
				rel="noopener"
				class="group rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur transition hover:border-fuchsia-400/30 hover:bg-white/[0.05]"
			>
				<div class="flex items-center justify-between">
					<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Watch</p>
					<svg class="h-4 w-4 text-slate-500 transition group-hover:translate-x-0.5 group-hover:text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
				</div>
				<p class="mt-3 text-base font-semibold text-white">Open the commercial on YouTube</p>
				<p class="mt-1 text-sm text-slate-400">Like, comment, and subscribe — it genuinely helps.</p>
			</a>

			<a
				href={twitterShare}
				target="_blank"
				rel="noopener"
				class="group rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur transition hover:border-fuchsia-400/30 hover:bg-white/[0.05]"
			>
				<div class="flex items-center justify-between">
					<p class="text-xs font-semibold uppercase tracking-widest text-fuchsia-300">Share</p>
					<svg class="h-4 w-4 text-slate-500 transition group-hover:translate-x-0.5 group-hover:text-fuchsia-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
				</div>
				<p class="mt-3 text-base font-semibold text-white">Tell someone who'd love this</p>
				<p class="mt-1 text-sm text-slate-400">Word-of-mouth is everything for an indie launch — thank you.</p>
			</a>
		</section>

		<div class="mt-12 text-center">
			<a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-slate-400 transition hover:text-white">
				<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
				Back to ultiplay.net
			</a>
		</div>
	</main>

	<Footer />
</Layout>
