---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import {
	LEGAL_EFFECTIVE_DATE,
	LEGAL_ROUTES,
	PUBLISHER,
	mailtoHref,
	EMAILS,
} from '../config/legal';
---

<Layout
	title="End User License Agreement — Ultiplay"
	description="The End User License Agreement (EULA) for the Ultiplay desktop application, including the Free / Gold tier definitions, restrictions, warranty disclaimer, and liability cap."
>
	<Nav />

	<main class="mx-auto max-w-3xl px-6 py-20 md:py-28">
		<header>
			<p class="text-sm font-semibold uppercase tracking-widest text-fuchsia-300">Legal</p>
			<h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
				End User License Agreement
