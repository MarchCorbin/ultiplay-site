---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Ultiplay — Your Play. Your Way.',
	description = 'Your Play. Your Way. Ultiplay is the multi-video player for Windows that scales from a single perfectly-controlled player to a full multi-screen video wall — with one-button cinematic layouts including Classic, Grid, Screen Maximize, and Mosaic Mode.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/ultiplay-hero.jpg" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="theme-color" content="#0b0514" />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-[#070310] text-slate-100 antialiased selection:bg-fuchsia-500/40 selection:text-white">
		<slot />
	</body>
</html>

<style is:global>
	@import "../styles/global.css";

	html {
		scroll-behavior: smooth;
	}

	body {
		background-image:
			radial-gradient(ellipse 80% 60% at 50% -10%, rgba(168, 85, 247, 0.22), transparent 60%),
			radial-gradient(ellipse 60% 50% at 90% 30%, rgba(34, 211, 238, 0.14), transparent 55%),
			radial-gradient(ellipse 60% 50% at 10% 70%, rgba(236, 72, 153, 0.18), transparent 55%);
	}
</style>
