---
interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

import Analytics from '@vercel/analytics/astro';
import Attribution from '../components/Attribution.astro';

const {
	title = 'Ultiplay — Your Play. Your Way.',
	description = 'Your Play. Your Way. Ultiplay is the multi-video player for Windows that scales from a single perfectly-controlled player to a full multi-screen video wall — with one-button cinematic layouts including Classic, Grid, Screen Maximize, and Mosaic Mode.',
	ogImage = '/ultiplay-hero.jpg',
	jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
		<link rel="apple-touch-icon" sizes="192x192" href="/favicon-192.png" />
		<link rel="apple-touch-icon" sizes="512x512" href="/favicon-512.png" />
		<link rel="canonical" href={canonicalURL} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0b0514" />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Ultiplay" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:alt" content="Ultiplay — multi-video player for Windows with one-button cinematic layouts" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<title>{title}</title>

		{jsonLd && (
			<script
				type="application/ld+json"
				is:inline
				set:html={JSON.stringify(jsonLd)}
			/>
		)}

		<Analytics />
	</head>
	<body class="min-h-screen bg-[#070310] text-slate-100 antialiased selection:bg-fuchsia-500/40 selection:text-white">
		<slot />
		<Attribution />

		<script>
			// Bridge: forward the analytics-agnostic `download` events that
			// Attribution.astro pushes onto window.dataLayer into Vercel Web
			// Analytics as a custom event. Keeps Attribution portable while
			// giving Vercel a per-source install count. (Custom events require
			// a Vercel Pro/Enterprise plan; page views are tracked on all plans.)
			import { track } from '@vercel/analytics';

			const w = window as any;
			w.dataLayer = w.dataLayer || [];
			const originalPush = w.dataLayer.push.bind(w.dataLayer);
			w.dataLayer.push = function (entry: any) {
				try {
					if (entry && entry.event === 'download') {
						track('download', {
							source: entry.utm_source || '(direct)',
							campaign: entry.utm_campaign || '',
						});
					}
				} catch (_) {
					/* never let analytics break navigation */
				}
				return originalPush(entry);
			};
		</script>
	</body>
</html>

<style is:global>
	@import "../styles/global.css";

	html {
		scroll-behavior: smooth;
	}

	body {
		background-image:
			radial-gradient(ellipse 80% 60% at 50% -10%, rgba(168, 85, 247, 0.22), transparent 60%),
			radial-gradient(ellipse 60% 50% at 90% 30%, rgba(34, 211, 238, 0.14), transparent 55%),
			radial-gradient(ellipse 60% 50% at 10% 70%, rgba(236, 72, 153, 0.18), transparent 55%);
	}
</style>
